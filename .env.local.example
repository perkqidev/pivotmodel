# ── Pivot Model · Environment Variables ──────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Database (SQLite file path — relative to project root)
DATABASE_PATH=./data/pivot.db

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=your-very-long-random-secret-here

# Email (for OTP verification) — SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="The Pivot Model <noreply@thepivotmodel.com>"

# Admin credentials (for /admin panel)
ADMIN_EMAIL=admin@thepivotmodel.com
ADMIN_PASSWORD_HASH=

# Site URL (used for email links)
NEXT_PUBLIC_SITE_URL=https://thepivotmodel.com

# OTP expiry in minutes
OTP_EXPIRY_MINUTES=10
