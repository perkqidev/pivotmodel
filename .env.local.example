# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/pivot_model
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# Railway:  (copy from Railway dashboard)
# Neon:     (copy from Neon dashboard — add ?sslmode=require)
DATABASE_URL=postgresql://user:password@localhost:5432/pivot_model

# Set to "true" if your provider requires SSL (Supabase, Neon, Railway)
DATABASE_SSL=false

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_long_random_string

# Resend API key (resend.com) — for OTP email delivery
RESEND_API_KEY=re_your_api_key_here

# From address — must match a verified domain in your Resend account
SMTP_FROM=The Pivot Model <noreply@pivotmodel.org>

# OTP expiry in minutes (default: 10)
OTP_EXPIRY_MINUTES=10

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://pivotmodel.org
